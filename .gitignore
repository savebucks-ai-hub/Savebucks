# ── Build outputs ────────────────────────────────────────────────────────────
.kotlin
.gradle
**/build/
!src/**/build/

# ── IDE ──────────────────────────────────────────────────────────────────────
*.iml
.idea
.DS_Store

# ── Android / iOS ────────────────────────────────────────────────────────────
local.properties
xcuserdata
captures
.externalNativeBuild
.cxx
*.xcodeproj/*
!*.xcodeproj/project.pbxproj
!*.xcodeproj/xcshareddata/
!*.xcodeproj/project.xcworkspace/
!*.xcworkspace/contents.xcworkspacedata
**/xcshareddata/WorkspaceSettings.xcsettings

# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
package-lock.json

# ── Environment files — NEVER commit real secrets ────────────────────────────
.env
.env.*
**/.env
**/.env.*
# .env.example files are templates with no real values — they SHOULD be committed
!.env.example
!**/.env.example

# ── Logs ─────────────────────────────────────────────────────────────────────
server/logs/
worker/logs/

# ── Frontend build output ────────────────────────────────────────────────────
**/app/web/dist/

# ── Claude Code — all machine-specific config, never commit ─────────────────
.claude/

# ── Supabase ─────────────────────────────────────────────────────────────────
/supabase/enable_rls.sql
