# Server
PORT=4000

# Supabase — get these from Project Settings > API in your Supabase dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE=eyJ...
# JWT Secret is under Settings > API > JWT Settings > JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_JWT_AUDIENCE=authenticated

# Upstash Redis — get URL from Upstash Console (rediss:// for TLS)
REDIS_URL=rediss://default:password@your-upstash-host.upstash.io:6380

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@savebucks.com

# CORS — comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://yourdomain.com

# Path to built React web app (relative to server working directory)
WEB_DIST_PATH=../web/dist
